<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="lab7.MainWindow"
        Title="lab7">

    <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="Wprowadź sekwencję DNA (ACGT):" FontWeight="Bold" />
    
    <TextBox Name="InputDNA" Watermark="Np. ACGTACGT..." />
    
    <Button Content="Zlicz sekwencje (4-mery)" 
            HorizontalAlignment="Center" 
            Click="ButtonClicked" />
    
    <Separator />
    <TextBlock Name="ResultText" Text="Wynik pojawi się tutaj..." TextWrapping="Wrap" />
</StackPanel>


</Window>
